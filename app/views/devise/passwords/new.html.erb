<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-5">
      <div class="card shadow-sm">
        <div class="card-body p-5">
          <h1 class="h3 mb-4 font-weight-bold text-center">Forgot Your Password?</h1>
          <p class="text-muted text-center mb-4">No problem. Enter your email and we'll send you a link to reset it.</p>

          <%= form_with(model: resource, local: true, url: user_password_path) do |f| %>
            <% if resource.errors.any? %>
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <h5 class="alert-heading"><%= pluralize(resource.errors.count, "error") %> occurred:</h5>
                <ul class="mb-0">
                  <% resource.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% end %>

            <div class="form-group mb-4">
              <%= f.label :email %>
              <%= f.email_field :email, class: "form-control #{"is-invalid" if resource.errors[:email].any?}", 
                  placeholder: "Enter your email address", autofocus: true, autocomplete: "email" %>
              <% if resource.errors[:email].any? %>
                <div class="invalid-feedback d-block">
                  <%= resource.errors[:email].join(", ") %>
                </div>
              <% end %>
            </div>

            <div class="form-group">
              <%= f.submit "Send Password Reset Link", class: "btn btn-primary w-100 mb-3" %>
            </div>

            <hr class="my-4">

            <div class="text-center mb-2">
              <%= link_to "Back to Sign In", new_user_session_path, class: "text-muted" %>
            </div>

            <div class="text-center">
              <%= link_to "Create Account", new_user_registration_path, class: "text-muted" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
