<div class="max-w-3xl mx-auto py-10 px-4">
  <%= link_to "← Back to Dashboard", dashboard_path, class: "text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block" %>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
    <%# --- Standup Header --- %>
    <div class="p-8 border-b border-gray-100 bg-gray-50/50">
      <div class="flex items-center gap-3 mb-4">
        <span class="h-10 w-10 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold">
          <%= @standup.user.full_name[0] %>
        </span>
        <div>
          <h1 class="font-bold text-xl text-gray-900"><%= @standup.user.full_name %></h1>
          <p class="text-sm text-gray-500"><%= @standup.created_at_date.strftime("%B %d, %Y") %></p>
        </div>
      </div>

      <%# --- Content Grid --- %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <p class="text-[10px] font-black text-blue-500 uppercase tracking-widest mb-2">Yesterday</p>
          <p class="text-gray-700 leading-relaxed"><%= @standup.worked_on_yesterday %></p>
        </div>
        <div>
          <p class="text-[10px] font-black text-emerald-500 uppercase tracking-widest mb-2">Today's Plan</p>
          <p class="text-gray-900 font-medium leading-relaxed"><%= @standup.plan_for_today %></p>
        </div>
      </div>
      
      <% if @standup.needs_help %>
        <div class="mt-6 p-4 bg-red-50 border border-red-100 rounded-xl">
          <p class="text-[10px] font-black text-red-600 uppercase mb-1">Blocker / Help Needed</p>
          <p class="text-sm text-red-800 font-semibold"><%= @standup.blockers %></p>
        </div>
      <% end %>
    </div>

    <%# --- COMMENT SECTION (ST-05) --- %>
    <div class="p-8 bg-white">
      <h3 class="font-bold text-gray-800 mb-6 flex items-center">
        Comments <span class="ml-2 px-2 py-0.5 bg-gray-100 text-gray-400 text-xs rounded-full"><%= @standup.comments.count %></span>
      </h3>
      
      <div id="comments_list" class="space-y-2 mb-8">
        <% if @standup.comments.exists? %>
          <%# This line triggers Rails to look for app/views/comments/_comment.html.erb %>
          <%= render @standup.comments %>
        <% else %>
          <p class="text-gray-400 text-sm italic py-4">No comments yet. Start the discussion!</p>
        <% end %>
      </div>

      <%# --- New Comment Form --- %>
      <div class="border-t pt-6">
        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-4">Leave a comment</p>
        
        <%= form_with(model: [@standup, Comment.new], local: true, class: "space-y-4") do |f| %>
          <div>
            <%= f.text_area :body, rows: 3, 
                class: "w-full rounded-xl border-gray-300 focus:ring-blue-500 focus:border-blue-500 text-sm p-4 bg-gray-50", 
                placeholder: "Type your comment here..." %>
          </div>
          
          <div class="flex justify-end">
            <%= f.submit "Post Comment", 
                class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-bold text-sm transition shadow-sm cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>